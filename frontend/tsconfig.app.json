{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/vite-env.d.ts",
    "src/app/**/*.ts",
    "src/types/**/*.ts",
    "src/lib/**/*.ts",
    "src/hooks/**/*.ts",
    "src/pages/**/*.ts",
    "src/pages/**/*.tsx",
    "src/components/layout/AppLayout.tsx",
    "src/components/layout/Page.tsx",
    "src/components/modals/**/*.ts",
    "src/components/modals/**/*.tsx",
    "src/components/forms/ApproveForm.tsx",
    "src/components/forms/DateTimePicker.tsx",
    "src/components/forms/EventForm.tsx",
    "src/components/forms/OrganizationCreateForm.tsx",
    "src/components/forms/PaymentUploadForm.tsx",
    "src/components/forms/UserCreateForm.tsx",
    "src/components/ui/Alert.tsx",
    "src/components/ui/Badge.tsx",
    "src/components/ui/Button.tsx",
    "src/components/ui/EmptyState.tsx",
    "src/components/ui/Field.tsx",
    "src/components/ui/Info.tsx",
    "src/components/ui/Panel.tsx",
    "src/components/ui/Select.tsx",
    "src/components/ui/Stat.tsx",
    "src/components/ui/Table.tsx"
  ]
}
